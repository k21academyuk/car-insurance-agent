LANGSMITH_API_KEY=
LANGSMITH_PROJECT=car-insurance-agent
LANGSMITH_TRACING=false

# ─── App config ────────────────────────────────────────
CORS_ORIGINS=*
CHROMA_PERSIST_DIR=/app/chroma_db
LOG_LEVEL=INFO
